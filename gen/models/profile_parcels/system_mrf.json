                    "minLength": 1,
                    "maxLength": 128
                  },
                  "default": {
                    "minimum": 1,
                    "maximum": 63,
                    "type": "integer"
                  },
                  "description": {
                    "minLength": 1,
                    "type": "string",
                    "maxLength": 128
                  }
                },
                "required": ["optionType", "value"],
                "additionalProperties": false
